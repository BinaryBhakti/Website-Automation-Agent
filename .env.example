# ---------------------------------------------------------------------------
# Website Automation Agent — configuration
# Copy this file to ".env" and fill in your real values.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# REQUIRED: your Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Primary Gemini model used for the agent's reasoning (vision + function calling).
# Free-tier daily quotas differ a LOT between models, so pick by headroom:
#   gemini-2.0-flash-lite -> highest free limits (best for the free tier)  [recommended]
#   gemini-2.0-flash      -> high limits, a bit smarter
#   gemini-2.5-flash      -> smartest of the flashes, but only ~20 requests/day on free tier
GEMINI_MODEL=gemini-2.0-flash-lite

# Fallback chain (optional). Each model has its OWN free-tier quota, so when one
# returns "quota exceeded" (HTTP 429) the agent automatically rotates to the next.
# Comma-separated, tried left to right. If unset, a sensible default chain is used
# (the primary model above, then gemini-2.0-flash, gemini-2.5-flash-lite,
# gemini-2.0-flash-lite). Set this to override the whole chain.
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite

# The page the agent should automate.
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# Free-form task the agent is asked to accomplish. The AI decides HOW to do it
# (which fields, what to type, when to scroll, when it is done).
TASK=Identify the form's Name (or primary/title) field and its Description field, then fill both with sensible, realistic values. Do not submit the form.

# Browser settings
# HEADLESS=false  -> a visible browser window opens (best for the live viva demo)
# HEADLESS=true   -> runs invisibly in the background
HEADLESS=false
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# Maximum number of reasoning/action steps before the agent gives up.
MAX_STEPS=30

# Default action timeout in milliseconds (navigation, clicks, etc.)
ACTION_TIMEOUT_MS=30000

# Folder where screenshots and logs are written.
ARTIFACTS_DIR=artifacts
