# ---------------------------------------------------------------------------
# Website Automation Agent — configuration
#
# This file is OPTIONAL. The agent runs with sensible defaults and needs NO
# API key. Copy it to ".env" only if you want to override any setting:
#   cp .env.example .env
# ---------------------------------------------------------------------------

# The page the agent should automate.
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# Values the agent types into the detected fields.
NAME_VALUE=Jane Doe
DESCRIPTION_VALUE=An automated submission created by the Website Automation Agent.

# Browser settings
# HEADLESS=false  -> a visible browser window opens (best for the live viva demo)
# HEADLESS=true   -> runs invisibly in the background
HEADLESS=false
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# Default action timeout in milliseconds (navigation, clicks, etc.)
ACTION_TIMEOUT_MS=30000

# Folder where screenshots and logs are written.
ARTIFACTS_DIR=artifacts
